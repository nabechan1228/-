# ==================================================
# HouseMaker API 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# ==================================================

# --- MySQL設定 ---
MYSQL_USER=housemaker_user
MYSQL_PASSWORD=your-secure-password-here
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=housemaker_db

# --- JWT設定 ---
# 以下のコマンドで安全なキーを生成:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# --- CORS設定（カンマ区切り） ---
ALLOWED_ORIGINS=http://localhost:3000

# --- 管理者認証 ---
ADMIN_USERNAME=admin
# 以下のコマンドでパスワードをハッシュ化:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=

# --- SMTP設定（自動返信メール用、空の場合はテストモード） ---
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@example.com
SMTP_FROM_NAME=渡部工務店

# --- サイトURL ---
SITE_URL=http://localhost:3000
